# ─── Auth (Supabase) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # server-only, never expose to client

# ─── Auth (Google OAuth) ──────────────────────────────────────
# Standard Next.js / Supabase OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Web OAuth client (if separate from above — used for Search Console / GA4 user auth)
GOOGLE_OAUTH_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_WEB_CLIENT_SECRET=your-web-client-secret

# ─── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...

# ─── APIs ─────────────────────────────────────────────────────
# Google AI (Gemini) — used by agent pipeline
GEMINI_API_KEY=your-gemini-api-key-here

# DataForSEO — keyword research and SERP data
DATAFORSEO_LOGIN=your-dataforseo-login-email
DATAFORSEO_PASSWORD=your-dataforseo-password

# Serper — Google Search results API
SERPER_API_KEY=your-serper-api-key

# Google PageSpeed Insights API
PAGESPEED_API_KEY=your-pagespeed-api-key

# Google Search Console — path to stored OAuth token file (server-side)
GSC_TOKEN_PATH=/path/to/gsc-token.json

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX)
GA=G-XXXXXXXXXX

# ─── Email ────────────────────────────────────────────────────
# Resend — transactional email
RESEND_API_KEY=re_...
# From address for outgoing emails
EMAIL_FROM=hello@yourdomain.com
# Support email shown in UI and footer
SUPPORT_EMAIL=support@yourdomain.com

# ─── Admin ────────────────────────────────────────────────────
# Comma-separated admin email addresses
ADMIN_EMAILS=admin@yourdomain.com,another@yourdomain.com
# Master password for admin panel (hashed in production)
ADMIN_MASTER_PASSWORD=your-secure-admin-password
# Secret token for authenticating cron job requests
CRON_SECRET=your-random-cron-secret

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public site URL (used in og:url, canonical links, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Queue Worker (optional) ──────────────────────────────────
QUEUE_POLL_INTERVAL_MS=10000
QUEUE_WORKER_LOG_LEVEL=info
